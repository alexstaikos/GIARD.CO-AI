{% style %}
  #shopify-section-{{ section.id }} { background: {{ section.settings.bg_color }}; padding: var(--lp-section-padding, 40px) 24px; }
  #shopify-section-{{ section.id }} .lp-approach__inner { max-width: 860px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .lp-approach__headline { font-family: var(--lp-font-heading, 'Anton', Georgia, serif); font-size: clamp(24px, 3.5vw, {{ section.settings.heading_size }}px); font-weight: 400; color: {{ section.settings.heading_color }}; line-height: 1.05; margin-bottom: 48px; text-transform: none; text-align: center; }
  #shopify-section-{{ section.id }} .lp-approach__list { display: flex; flex-direction: column; gap: 32px; }
  #shopify-section-{{ section.id }} .lp-approach__item { display: grid; grid-template-columns: 48px 1fr; gap: 20px; align-items: start; padding-bottom: 32px; border-bottom: 1px solid #e5e0d4; }
  #shopify-section-{{ section.id }} .lp-approach__item:last-child { border-bottom: none; padding-bottom: 0; }
  #shopify-section-{{ section.id }} .lp-approach__icon { width: 48px; height: 48px; background: var(--lp-icon-bg, #f3ede0); color: var(--lp-icon-color, #65222d); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-family: var(--lp-font-heading, 'Anton', Georgia, serif); }
  #shopify-section-{{ section.id }} .lp-approach__title { font-family: var(--lp-font-heading, 'Anton', Georgia, serif); font-size: 20px; font-weight: 400; color: {{ section.settings.heading_color }}; margin-bottom: 8px; text-transform: none; }
  #shopify-section-{{ section.id }} .lp-approach__body { font-family: var(--lp-font-body, 'Inter', sans-serif); font-size: {{ section.settings.body_size }}px; color: {{ section.settings.body_color }}; line-height: 1.7; }
  #shopify-section-{{ section.id }} .lp-approach__cta-wrap { text-align: center; margin-top: 48px; }
  #shopify-section-{{ section.id }} .lp-btn {
    background: {{ section.settings.btn_bg_color }} !important;
    color: {{ section.settings.btn_text_color }} !important;
    font-size: {{ section.settings.btn_text_size }}px !important;
    border-radius: {{ section.settings.btn_radius }}px !important;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px !important;
    text-transform: none !important;
    font-variant: normal !important;
    font-family: var(--lp-font-body, 'Inter', sans-serif) !important;
    display: inline-block !important;
    text-decoration: none !important;
    border: none !important;
    cursor: pointer !important;
    transition: opacity 0.2s !important;
  }
  #shopify-section-{{ section.id }} .lp-btn:hover { opacity: 0.88 !important; }
  @media(max-width: 600px) { #shopify-section-{{ section.id }} .lp-approach__item { grid-template-columns: 40px 1fr; } #shopify-section-{{ section.id }} .lp-approach__icon { width: 40px; height: 40px; } }
{% endstyle %}
<div class="lp-approach" id="how-we-work"><div class="lp-approach__inner">
  <h2 class="lp-approach__headline">{{ section.settings.headline | default: 'Our approach' }}</h2>
  <div class="lp-approach__list">
    {% assign item_number = 0 %}
    {% for i in (1..9) %}
      {% assign title_key = 'item' | append: i | append: '_title' %}
      {% assign body_key = 'item' | append: i | append: '_body' %}
      {% if section.settings[title_key] != blank %}
        {% assign item_number = item_number | plus: 1 %}
        <div class="lp-approach__item">
          <div class="lp-approach__icon">{{ item_number }}</div>
          <div>
            <div class="lp-approach__title">{{ section.settings[title_key] }}</div>
            <div class="lp-approach__body">{{ section.settings[body_key] }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  {% if section.settings.cta_text != blank %}
    <div class="lp-approach__cta-wrap">
      <a href="{{ section.settings.cta_url }}" class="lp-btn">{{ section.settings.cta_text }}</a>
    </div>
  {% endif %}
</div></div>
{% schema %}
{
  "name": "LP Approach",
  "settings": [
    {"type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff"},
    {"type": "text", "id": "headline", "label": "Headline", "default": "Our approach"},
    {"type": "header", "content": "Item 1"},
    {"type": "text", "id": "item1_title", "label": "Title", "default": "The Operating Review (diagnosis first)"},
    {"type": "textarea", "id": "item1_body", "label": "Body"},
    {"type": "header", "content": "Item 2"},
    {"type": "text", "id": "item2_title", "label": "Title", "default": "Product Marketing (fix the foundation)"},
    {"type": "textarea", "id": "item2_body", "label": "Body"},
    {"type": "header", "content": "Item 3"},
    {"type": "text", "id": "item3_title", "label": "Title", "default": "Brand Clarity"},
    {"type": "textarea", "id": "item3_body", "label": "Body"},
    {"type": "header", "content": "Item 4"},
    {"type": "text", "id": "item4_title", "label": "Title", "default": "AI Workflows (the ops stack on your systems)"},
    {"type": "textarea", "id": "item4_body", "label": "Body"},
    {"type": "header", "content": "Item 5"},
    {"type": "text", "id": "item5_title", "label": "Title", "default": "Media Library"},
    {"type": "textarea", "id": "item5_body", "label": "Body"},
    {"type": "header", "content": "Item 6"},
    {"type": "text", "id": "item6_title", "label": "Title", "default": "Briefing"},
    {"type": "textarea", "id": "item6_body", "label": "Body"},
    {"type": "header", "content": "Item 7"},
    {"type": "text", "id": "item7_title", "label": "Title", "default": "Owned Channel Activation"},
    {"type": "textarea", "id": "item7_body", "label": "Body"},
    {"type": "header", "content": "Item 8"},
    {"type": "text", "id": "item8_title", "label": "Title", "default": "Paid Media"},
    {"type": "textarea", "id": "item8_body", "label": "Body"},
    {"type": "header", "content": "Item 9"},
    {"type": "text", "id": "item9_title", "label": "Title", "default": "Fundraising & Recruiting (when it applies)"},
    {"type": "textarea", "id": "item9_body", "label": "Body"},
    {"type": "header", "content": "End of section CTA"},
    {"type": "text", "id": "cta_text", "label": "Button text", "default": "See what's included"},
    {"type": "url", "id": "cta_url", "label": "Button URL"},
    {"type": "header", "content": "Heading Style"},
    {"type": "color", "id": "heading_color", "label": "Heading color", "default": "#0a0a0a"},
    {"type": "range", "id": "heading_size", "label": "Heading size (px)", "min": 24, "max": 120, "step": 2, "default": 56},
    {"type": "header", "content": "Body Style"},
    {"type": "color", "id": "body_color", "label": "Body color", "default": "#555555"},
    {"type": "range", "id": "body_size", "label": "Body size (px)", "min": 12, "max": 28, "step": 1, "default": 16},
    {"type": "header", "content": "Button Style"},
    {"type": "color", "id": "btn_bg_color", "label": "Button background", "default": "#d18285"},
    {"type": "color", "id": "btn_text_color", "label": "Button text color", "default": "#ffffff"},
    {"type": "range", "id": "btn_text_size", "label": "Button text size (px)", "min": 12, "max": 24, "step": 1, "default": 16},
    {"type": "range", "id": "btn_radius", "label": "Corner radius (px)", "min": 0, "max": 40, "step": 1, "default": 10},
    {"type": "range", "id": "btn_padding_v", "label": "Vertical padding (px)", "min": 8, "max": 40, "step": 2, "default": 16},
    {"type": "range", "id": "btn_padding_h", "label": "Horizontal padding (px)", "min": 16, "max": 80, "step": 4, "default": 40}
  ],
  "presets": [{"name": "LP Approach"}]
}
{% endschema %}
