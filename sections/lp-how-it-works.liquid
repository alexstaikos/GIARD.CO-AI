{% style %}
  #shopify-section-{{ section.id }} { background: {{ section.settings.bg_color }}; padding: 24px 24px var(--lp-section-padding, 40px); text-align: center; overflow-x: hidden; }
  #shopify-section-{{ section.id }} .lp-hiw__eyebrow { color: {{ section.settings.eyebrow_color }}; font-size: {{ section.settings.eyebrow_size }}px; text-transform: none; letter-spacing: 0.02em; margin-bottom: 12px; display: block; }
  #shopify-section-{{ section.id }} .lp-hiw__headline { font-family: var(--lp-font-heading, 'Anton', Georgia, serif); font-size: clamp(24px, 4vw, {{ section.settings.heading_size }}px); font-weight: 400; color: {{ section.settings.heading_color }}; max-width: 700px; margin: 0 auto 60px; line-height: 1.0; text-transform: none; }
  #shopify-section-{{ section.id }} .lp-hiw__steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; max-width: 1000px; margin: 0 auto 48px; }
  #shopify-section-{{ section.id }} .lp-hiw__step-icon { width: 48px; height: 48px; background: var(--lp-icon-bg, #f3ede0); color: var(--lp-icon-color, #65222d); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-family: var(--lp-font-heading, 'Anton', Georgia, serif); margin: 0 auto 16px; }
  #shopify-section-{{ section.id }} .lp-hiw__step-title { font-family: var(--lp-font-heading, 'Anton', Georgia, serif); font-size: {{ section.settings.subheading_size }}px; font-weight: 400; color: {{ section.settings.subheading_color }}; margin-bottom: 12px; text-transform: none; }
  #shopify-section-{{ section.id }} .lp-hiw__step-body { font-family: var(--lp-font-body, 'Inter', sans-serif); font-size: {{ section.settings.body_size }}px; color: {{ section.settings.body_color }}; line-height: 1.6; }
  #shopify-section-{{ section.id }} .lp-btn {
    background: {{ section.settings.btn_bg_color }} !important;
    color: {{ section.settings.btn_text_color }} !important;
    font-size: {{ section.settings.btn_text_size }}px !important;
    border-radius: {{ section.settings.btn_radius }}px !important;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px !important;
    text-transform: none !important;
    font-variant: normal !important;
    font-family: var(--lp-font-body, 'Inter', sans-serif) !important;
    display: inline-block !important;
    text-decoration: none !important;
    border: none !important;
    cursor: pointer !important;
    transition: opacity 0.2s !important;
  }
  #shopify-section-{{ section.id }} .lp-btn:hover { opacity: 0.88 !important; }
  @media(max-width: 768px) { #shopify-section-{{ section.id }} .lp-hiw__steps { grid-template-columns: 1fr; } }
{% endstyle %}
<div class="lp-hiw">
  {% if section.settings.eyebrow != blank %}<span class="lp-hiw__eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
  <h2 class="lp-hiw__headline">{{ section.settings.headline }}</h2>
  <div class="lp-hiw__steps">
    <div class="lp-hiw__step"><div class="lp-hiw__step-icon">1</div><div class="lp-hiw__step-title">{{ section.settings.step1_title }}</div><div class="lp-hiw__step-body">{{ section.settings.step1_body }}</div></div>
    <div class="lp-hiw__step"><div class="lp-hiw__step-icon">2</div><div class="lp-hiw__step-title">{{ section.settings.step2_title }}</div><div class="lp-hiw__step-body">{{ section.settings.step2_body }}</div></div>
    <div class="lp-hiw__step"><div class="lp-hiw__step-icon">&#10003;</div><div class="lp-hiw__step-title">{{ section.settings.step3_title }}</div><div class="lp-hiw__step-body">{{ section.settings.step3_body }}</div></div>
  </div>
  <a href="{{ section.settings.cta_url }}" class="lp-btn">{{ section.settings.cta_text }}</a>
</div>
{% schema %}
{
  "name": "LP How It Works",
  "settings": [
    {"type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff"},
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your path to premium pricing"},
    {"type": "text", "id": "headline", "label": "Headline", "default": "Ready to escape commoditization?"},
    {"type": "header", "content": "Step 1"},
    {"type": "text", "id": "step1_title", "label": "Title", "default": "Schedule Your Strategy Session"},
    {"type": "textarea", "id": "step1_body", "label": "Body", "default": "Book a strategy call with our team."},
    {"type": "header", "content": "Step 2"},
    {"type": "text", "id": "step2_title", "label": "Title", "default": "Comprehensive Shopify and AD Analysis"},
    {"type": "textarea", "id": "step2_body", "label": "Body", "default": "We'll review your active ad library and Shopify store."},
    {"type": "header", "content": "Step 3"},
    {"type": "text", "id": "step3_title", "label": "Title", "default": "Custom Marketing Strategy"},
    {"type": "textarea", "id": "step3_body", "label": "Body", "default": "We'll breakdown the marketing strategies we would implement immediately for you."},
    {"type": "header", "content": "CTA"},
    {"type": "text", "id": "cta_text", "label": "Button text", "default": "Book your strategy call now"},
    {"type": "url", "id": "cta_url", "label": "Button URL"},
    {"type": "header", "content": "Eyebrow Style"},
    {"type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#d18285"},
    {"type": "range", "id": "eyebrow_size", "label": "Eyebrow size (px)", "min": 10, "max": 24, "step": 1, "default": 13},
    {"type": "header", "content": "Heading Style"},
    {"type": "color", "id": "heading_color", "label": "Heading color", "default": "#0a0a0a"},
    {"type": "range", "id": "heading_size", "label": "Heading size (px)", "min": 24, "max": 120, "step": 2, "default": 56},
    {"type": "header", "content": "Subheading Style"},
    {"type": "color", "id": "subheading_color", "label": "Subheading color", "default": "#0a0a0a"},
    {"type": "range", "id": "subheading_size", "label": "Subheading size (px)", "min": 14, "max": 48, "step": 1, "default": 22},
    {"type": "header", "content": "Body Style"},
    {"type": "color", "id": "body_color", "label": "Body color", "default": "#555555"},
    {"type": "range", "id": "body_size", "label": "Body size (px)", "min": 12, "max": 28, "step": 1, "default": 16},
    {"type": "header", "content": "Button Style"},
    {"type": "color", "id": "btn_bg_color", "label": "Button background", "default": "#65222d"},
    {"type": "color", "id": "btn_text_color", "label": "Button text color", "default": "#ffffff"},
    {"type": "range", "id": "btn_text_size", "label": "Button text size (px)", "min": 12, "max": 24, "step": 1, "default": 16},
    {"type": "range", "id": "btn_radius", "label": "Corner radius (px)", "min": 0, "max": 40, "step": 1, "default": 10},
    {"type": "range", "id": "btn_padding_v", "label": "Vertical padding (px)", "min": 8, "max": 40, "step": 2, "default": 16},
    {"type": "range", "id": "btn_padding_h", "label": "Horizontal padding (px)", "min": 16, "max": 80, "step": 4, "default": 40}
  ],
  "presets": [{"name": "LP How It Works"}]
}
{% endschema %}
