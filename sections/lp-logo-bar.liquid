{{ 'lp-brand.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: 40px 24px;
    text-align: center;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .lp-logos__label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #0a0a0a;
    margin-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .lp-logos__track-wrap {
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .lp-logos__track {
    display: flex;
    gap: 60px;
    align-items: center;
    animation: lp-marquee 22s linear infinite;
    width: max-content;
  }
  #shopify-section-{{ section.id }} .lp-logos__track:hover {
    animation-play-state: paused;
  }
  #shopify-section-{{ section.id }} .lp-logos__logo {
    height: 32px;
    object-fit: contain;
    opacity: 0.7;
    filter: grayscale(1);
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .lp-logos__name {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #555;
    flex-shrink: 0;
    opacity: 0.7;
  }
  @keyframes lp-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
{% endstyle %}

<div class="lp-logos">
  {% if section.settings.label != blank %}
    <p class="lp-logos__label">{{ section.settings.label }}</p>
  {% endif %}
  <div class="lp-logos__track-wrap">
    <div class="lp-logos__track">
      {% for i in (1..8) %}
        {% assign img_key = 'logo' | append: i | append: '_img' %}
        {% assign name_key = 'logo' | append: i | append: '_name' %}
        {% if section.settings[img_key] %}
          <img src="{{ section.settings[img_key] | image_url: width: 200 }}" alt="{{ section.settings[name_key] }}" class="lp-logos__logo">
        {% elsif section.settings[name_key] != blank %}
          <span class="lp-logos__name">{{ section.settings[name_key] }}</span>
        {% endif %}
      {% endfor %}
      {% for i in (1..8) %}
        {% assign img_key = 'logo' | append: i | append: '_img' %}
        {% assign name_key = 'logo' | append: i | append: '_name' %}
        {% if section.settings[img_key] %}
          <img src="{{ section.settings[img_key] | image_url: width: 200 }}" alt="{{ section.settings[name_key] }}" class="lp-logos__logo">
        {% elsif section.settings[name_key] != blank %}
          <span class="lp-logos__name">{{ section.settings[name_key] }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

