
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="featured-editorial color-{{ section.settings.color_scheme }}"
  id="FeaturedEditorial-{{ section.id }}"
>
  <div
    class="featured-editorial__container section section--{{ section.settings.section_width }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="featured-editorial__track" data-fe-track>
      {%- for block in section.blocks -%}
        <div
          class="featured-editorial__slide{% if forloop.first %} is-active{% endif %}"
          data-slide="{{ forloop.index0 }}"
          aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="featured-editorial__content">
            {%- if block.settings.eyebrow != blank -%}
              <p class="featured-editorial__eyebrow">
                <span aria-hidden="true">✦</span>
                {{ block.settings.eyebrow }}
                <span aria-hidden="true">✦</span>
              </p>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              <h2 class="featured-editorial__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}

            {%- if block.settings.body != blank -%}
              <p class="featured-editorial__body">{{ block.settings.body }}</p>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a
                href="{{ block.settings.button_link | default: '#' }}"
                class="featured-editorial__cta"
              >
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}

            {%- if section.blocks.size > 1 -%}
              <div class="featured-editorial__nav">
                <button
                  class="featured-editorial__nav-btn featured-editorial__nav-btn--prev"
                  data-fe-prev
                  aria-label="Previous"
                >
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M11 14L6 9L11 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button
                  class="featured-editorial__nav-btn featured-editorial__nav-btn--next"
                  data-fe-next
                  aria-label="Next"
                >
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            {%- endif -%}
          </div>

          <div class="featured-editorial__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1000
                | image_tag:
                  loading: 'lazy',
                  class: 'featured-editorial__image',
                  widths: '500, 700, 900, 1000',
                  sizes: '(min-width: 750px) 44vw, 100vw',
                  alt: block.settings.image.alt | escape
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'featured-editorial__image featured-editorial__image--placeholder' }}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .featured-editorial {
    position: relative;
    overflow: hidden;
  }

  .featured-editorial__slide {
    display: none;
  }

  .featured-editorial__slide.is-active {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .featured-editorial__slide.is-active {
      grid-template-columns: 55fr 45fr;
      gap: clamp(32px, 5vw, 72px);
    }
  }

  /* Content column */
  .featured-editorial__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .featured-editorial__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0;
    opacity: 0.7;
    font-weight: 500;
  }

  .featured-editorial__heading {
    font-size: clamp(2.5rem, 6.5vw, 5rem);
    line-height: 1.0;
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .featured-editorial__body {
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
    opacity: 0.75;
    max-width: 38ch;
  }

  /* Pill CTA button */
  .featured-editorial__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2.25rem;
    border: 1.5px solid currentColor;
    border-radius: 100px;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    font-weight: 500;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .featured-editorial__cta:hover {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }

  /* Split pill nav */
  .featured-editorial__nav {
    display: flex;
    align-items: center;
  }

  .featured-editorial__nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 42px;
    background: transparent;
    border: 1.5px solid currentColor;
    color: inherit;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .featured-editorial__nav-btn--prev {
    border-radius: 100px 0 0 100px;
    border-right-width: 0.75px;
  }

  .featured-editorial__nav-btn--next {
    border-radius: 0 100px 100px 0;
    border-left-width: 0.75px;
  }

  .featured-editorial__nav-btn:hover {
    background-color: var(--color-foreground);
    color: var(--color-background);
  }

  /* Media column */
  .featured-editorial__media {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: rgba(128 128 128 / 0.08);
  }

  .featured-editorial__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-editorial__image--placeholder {
    padding: 3rem;
    opacity: 0.25;
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    document.querySelectorAll('[id^="FeaturedEditorial-"]').forEach(section => {
      const slides = [...section.querySelectorAll('[data-slide]')];
      if (slides.length <= 1) return;
      let current = 0;

      const show = (idx) => {
        slides[current].classList.remove('is-active');
        slides[current].setAttribute('aria-hidden', 'true');
        current = (idx + slides.length) % slides.length;
        slides[current].classList.add('is-active');
        slides[current].setAttribute('aria-hidden', 'false');
      };

      section.querySelectorAll('[data-fe-prev]').forEach(btn =>
        btn.addEventListener('click', () => show(current - 1))
      );
      section.querySelectorAll('[data-fe-next]').forEach(btn =>
        btn.addEventListener('click', () => show(current + 1))
      );
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Featured Editorial",
  "class": "section-wrapper",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "name": "Slide",
      "type": "slide",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow label",
          "default": "Featured"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Product Name"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text",
          "default": "A short, compelling description of this product."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Featured Editorial",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New Arrivals",
            "heading": "Product Name",
            "body": "A short, compelling description of this product.",
            "button_label": "Shop Now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
