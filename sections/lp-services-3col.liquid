{% style %}
  #shopify-section-{{ section.id }} { background: {{ section.settings.bg_color }}; padding: var(--lp-section-padding, 40px) 24px 24px; text-align: center; }
  #shopify-section-{{ section.id }} .lp-svc__eyebrow { color: {{ section.settings.eyebrow_color }}; font-size: {{ section.settings.eyebrow_size }}px; text-transform: none; letter-spacing: 0.02em; margin-bottom: 14px; display: block; }
  #shopify-section-{{ section.id }} .lp-svc__headline { font-family: var(--lp-font-heading, 'Anton', Georgia, serif); font-size: clamp(24px, 4vw, {{ section.settings.heading_size }}px); font-weight: 400; color: {{ section.settings.heading_color }}; line-height: 1.0; max-width: 700px; margin: 0 auto 60px; text-transform: none; }
  #shopify-section-{{ section.id }} .lp-svc__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; max-width: 1100px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .lp-svc__title { font-family: var(--lp-font-heading, 'Anton', Georgia, serif); font-size: {{ section.settings.subheading_size }}px; font-weight: 400; color: {{ section.settings.subheading_color }}; margin-bottom: 16px; text-transform: none; }
  #shopify-section-{{ section.id }} .lp-svc__body { font-family: var(--lp-font-body, 'Inter', sans-serif); font-size: {{ section.settings.body_size }}px; color: {{ section.settings.body_color }}; line-height: 1.7; }
  @media(max-width: 768px) { #shopify-section-{{ section.id }} .lp-svc__grid { grid-template-columns: 1fr; } }
{% endstyle %}
<div class="lp-svc">
  {% if section.settings.eyebrow != blank %}<span class="lp-svc__eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
  <h2 class="lp-svc__headline">{{ section.settings.headline }}</h2>
  <div class="lp-svc__grid">
    {% for i in (1..3) %}
      {% assign title_key = 's' | append: i | append: '_title' %}
      {% assign body_key = 's' | append: i | append: '_body' %}
      <div class="lp-svc__item">
        <div class="lp-svc__title">{{ section.settings[title_key] }}</div>
        <div class="lp-svc__body">{{ section.settings[body_key] }}</div>
      </div>
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "LP Services 3col",
  "settings": [
    {"type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff"},
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lets have some fun"},
    {"type": "text", "id": "headline", "label": "Headline", "default": "What you can expect from being a portfolio member"},
    {"type": "header", "content": "Service 1"},
    {"type": "text", "id": "s1_title", "label": "Title", "default": "Ad Creation"},
    {"type": "textarea", "id": "s1_body", "label": "Body"},
    {"type": "header", "content": "Service 2"},
    {"type": "text", "id": "s2_title", "label": "Title", "default": "Paid Ad Management"},
    {"type": "textarea", "id": "s2_body", "label": "Body"},
    {"type": "header", "content": "Service 3"},
    {"type": "text", "id": "s3_title", "label": "Title", "default": "Shopify CRO"},
    {"type": "textarea", "id": "s3_body", "label": "Body"},
    {"type": "header", "content": "Eyebrow Style"},
    {"type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#d18285"},
    {"type": "range", "id": "eyebrow_size", "label": "Eyebrow size (px)", "min": 10, "max": 24, "step": 1, "default": 13},
    {"type": "header", "content": "Heading Style"},
    {"type": "color", "id": "heading_color", "label": "Heading color", "default": "#0a0a0a"},
    {"type": "range", "id": "heading_size", "label": "Heading size (px)", "min": 24, "max": 120, "step": 2, "default": 56},
    {"type": "header", "content": "Subheading Style"},
    {"type": "color", "id": "subheading_color", "label": "Subheading color", "default": "#0a0a0a"},
    {"type": "range", "id": "subheading_size", "label": "Subheading size (px)", "min": 14, "max": 48, "step": 1, "default": 22},
    {"type": "header", "content": "Body Style"},
    {"type": "color", "id": "body_color", "label": "Body color", "default": "#555555"},
    {"type": "range", "id": "body_size", "label": "Body size (px)", "min": 12, "max": 28, "step": 1, "default": 16}
  ],
  "presets": [{"name": "LP Services 3col"}]
}
{% endschema %}
