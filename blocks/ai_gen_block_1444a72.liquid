        {% endif %}
      {% endif %}
      <div class="ai-text-block-content-{{ ai_gen_id }}">
        {{ block.settings.block_2_text }}
      </div>
    </div>

    <div class="ai-text-block-{{ ai_gen_id }}">
      {% if block.settings.block_3_heading != blank %}
        {% if block.settings.block_heading_type == 'h1' %}
          <h1 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_3_heading }}</h1>
        {% elsif block.settings.block_heading_type == 'h2' %}
          <h2 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_3_heading }}</h2>
        {% elsif block.settings.block_heading_type == 'h3' %}
          <h3 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_3_heading }}</h3>
        {% elsif block.settings.block_heading_type == 'h4' %}
          <h4 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_3_heading }}</h4>
        {% elsif block.settings.block_heading_type == 'h5' %}
