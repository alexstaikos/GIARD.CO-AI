{% doc %}
  @prompt
    make a section with 4 blocks that are rounded and next to each other that I can put text in and include a header. make sure I can change the font, header type, colors, corner radius for all, add headings within each block as well, make it so there is a glow around each box that I can change the color of and make them move when you hover over them
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-blocks-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
  }

  .ai-text-blocks-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: 30px;
    color: {{ block.settings.header_color }};
    font-family: {{ block.settings.header_font.family }}, {{ block.settings.header_font.fallback_families }};
    font-weight: {{ block.settings.header_font.weight }};
    font-style: {{ block.settings.header_font.style }};
  }

  .ai-text-blocks-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.block_spacing }}px;
  }

  .ai-text-block-{{ ai_gen_id }} {
    background-color: {{ block.settings.block_background_color }};
    border-radius: {{ block.settings.corner_radius }}px;
    padding: {{ block.settings.block_padding }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    box-shadow: 0 0 {{ block.settings.glow_size }}px {{ block.settings.glow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-text-block-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift }}px {{ block.settings.glow_size | plus: 10 }}px {{ block.settings.glow_color }};
  }

  .ai-text-block-heading-{{ ai_gen_id }} {
    color: {{ block.settings.block_heading_color }};
    font-family: {{ block.settings.block_heading_font.family }}, {{ block.settings.block_heading_font.fallback_families }};
    font-weight: {{ block.settings.block_heading_font.weight }};
    font-style: {{ block.settings.block_heading_font.style }};
    font-size: {{ block.settings.block_heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  .ai-text-block-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-style: {{ block.settings.text_font.style }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-text-blocks-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-text-blocks-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<text-blocks-{{ ai_gen_id }}
  class="ai-text-blocks-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.header != blank %}
    {% if block.settings.header_type == 'h1' %}
      <h1 class="ai-text-blocks-header-{{ ai_gen_id }}">{{ block.settings.header }}</h1>
    {% elsif block.settings.header_type == 'h2' %}
      <h2 class="ai-text-blocks-header-{{ ai_gen_id }}">{{ block.settings.header }}</h2>
    {% elsif block.settings.header_type == 'h3' %}
      <h3 class="ai-text-blocks-header-{{ ai_gen_id }}">{{ block.settings.header }}</h3>
    {% elsif block.settings.header_type == 'h4' %}
      <h4 class="ai-text-blocks-header-{{ ai_gen_id }}">{{ block.settings.header }}</h4>
    {% elsif block.settings.header_type == 'h5' %}
      <h5 class="ai-text-blocks-header-{{ ai_gen_id }}">{{ block.settings.header }}</h5>
    {% else %}
      <h6 class="ai-text-blocks-header-{{ ai_gen_id }}">{{ block.settings.header }}</h6>
    {% endif %}
  {% endif %}

  <div class="ai-text-blocks-grid-{{ ai_gen_id }}">
    <div class="ai-text-block-{{ ai_gen_id }}">
      {% if block.settings.block_1_heading != blank %}
        {% if block.settings.block_heading_type == 'h1' %}
          <h1 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h1>
        {% elsif block.settings.block_heading_type == 'h2' %}
          <h2 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h2>
        {% elsif block.settings.block_heading_type == 'h3' %}
          <h3 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h3>
        {% elsif block.settings.block_heading_type == 'h4' %}
          <h4 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h4>
        {% elsif block.settings.block_heading_type == 'h5' %}
          <h5 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h5>
        {% else %}
          <h6 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h6>
        {% endif %}
      {% endif %}
      <div class="ai-text-block-content-{{ ai_gen_id }}">
        {{ block.settings.block_1_text }}
      </div>
    </div>

    <div class="ai-text-block-{{ ai_gen_id }}">
      {% if block.settings.block_2_heading != blank %}
        {% if block.settings.block_heading_type == 'h1' %}
          <h1 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_2_heading }}</h1>
        {% elsif block.settings.block_heading_type == 'h2' %}
          <h2 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_2_heading }}</h2>
        {% elsif block.settings.block_heading_type == 'h3' %}
          <h3 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_2_heading }}</h3>
        {% elsif block.settings.block_heading_type == 'h4' %}
          <h4 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_2_heading }}</h4>
        {% elsif block.settings.block_heading_type == 'h5' %}
          <h5 class="ai-text-block-heading-{{ ai_gen_id }}">{{ block.settings.block_2_heading }}</h5>
        {% else %}
