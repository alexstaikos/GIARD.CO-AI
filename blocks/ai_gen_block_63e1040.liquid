{% doc %}
  @prompt
    generate me a logo carosel with each logo being the same size and being black. make it so I can adjust logo size, scroll speed and direction, and padding on top and bottom of section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-logo-carousel-track-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
    width: max-content;
  }

  .ai-logo-carousel-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_size }}px;
    height: {{ block.settings.logo_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-logo-carousel-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0);
  }

  .ai-logo-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-logo-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-carousel-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }
{% endstyle %}

<logo-carousel-{{ ai_gen_id }}
  class="ai-logo-carousel-{{ ai_gen_id }}"
  data-speed="{{ block.settings.scroll_speed }}"
  data-direction="{{ block.settings.scroll_direction }}"
  {{ block.shopify_attributes }}
>
  {% assign has_logos = false %}
  {% for i in (1..10) %}
    {% assign logo_key = 'logo_' | append: i %}
    {% if block.settings[logo_key] != blank %}
      {% assign has_logos = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if has_logos %}
    <div class="ai-logo-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% assign logo_key = 'logo_' | append: i %}
        {% if block.settings[logo_key] != blank %}
          <div class="ai-logo-carousel-item-{{ ai_gen_id }}">
            <img
              src="{{ block.settings[logo_key] | image_url: width: 400 }}"
              alt="Logo {{ i }}"
              loading="lazy"
              width="{{ block.settings.logo_size }}"
              height="{{ block.settings.logo_size }}"
            >
          </div>
        {% endif %}
      {% endfor %}
      {% for i in (1..10) %}
        {% assign logo_key = 'logo_' | append: i %}
        {% if block.settings[logo_key] != blank %}
          <div class="ai-logo-carousel-item-{{ ai_gen_id }}">
            <img
              src="{{ block.settings[logo_key] | image_url: width: 400 }}"
              alt="Logo {{ i }}"
              loading="lazy"
              width="{{ block.settings.logo_size }}"
              height="{{ block.settings.logo_size }}"
            >
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-logo-carousel-empty-state-{{ ai_gen_id }}">
      Next, add logos to display in the carousel
    </div>
  {% endif %}
</logo-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.animationId = null;
        this.position = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-logo-carousel-track-{{ ai_gen_id }}');
        
        if (!this.track) return;

        const speed = parseFloat(this.dataset.speed) || 1;
        const direction = this.dataset.direction || 'left';
        const pixelsPerSecond = speed * 50;
        
        let lastTime = performance.now();
        
        const animate = (currentTime) => {
          const deltaTime = (currentTime - lastTime) / 1000;
          lastTime = currentTime;
          
          const movement = pixelsPerSecond * deltaTime;
          
          if (direction === 'left') {
            this.position -= movement;
          } else {
            this.position += movement;
          }
          
          const trackWidth = this.track.scrollWidth / 2;
          
          if (direction === 'left' && this.position <= -trackWidth) {
            this.position += trackWidth;
          } else if (direction === 'right' && this.position >= trackWidth) {
            this.position -= trackWidth;
          }
          
          this.track.style.transform = `translateX(${this.position}px)`;
          
          this.animationId = requestAnimationFrame(animate);
        };
        
        this.animationId = requestAnimationFrame(animate);
      }

      disconnectedCallback() {
        if (this.animationId) {
          cancelAnimationFrame(this.animationId);
        }
      }
    }

    customElements.define('logo-carousel-{{ ai_gen_id }}', LogoCarousel{{ ai_gen_id }});
  })();
</script>

