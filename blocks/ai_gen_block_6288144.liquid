{% doc %}
  @prompt
    Generate me a logo marquee where I can change the scroll speed, padding, and logo size of all the logos. Make it so that I can add up to 20 logos. Keep it within the frame of the website, and make sure all logos turn black when uploaded. , its not scrolling
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-marquee-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    display: block;
    position: relative;
  }

  .ai-logo-marquee-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    width: max-content;
  }

  .ai-logo-marquee-track-{{ ai_gen_id }}.scrolling {
    animation: ai-logo-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-logo-marquee-{{ ai_gen_id }}:hover .ai-logo-marquee-track-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  .ai-logo-marquee-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.logo_size }}px;
    height: {{ block.settings.logo_size }}px;
  }

  .ai-logo-marquee-item-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: brightness(0);
  }

  .ai-logo-marquee-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-logo-marquee-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-logo-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-logo-marquee-item-{{ ai_gen_id }} {
      width: {{ block.settings.logo_size | times: 0.7 }}px;
      height: {{ block.settings.logo_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<logo-marquee-{{ ai_gen_id }} class="ai-logo-marquee-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-marquee-track-{{ ai_gen_id }}">
    {% liquid
      assign logo_count = 0
      for i in (1..20)
        assign logo_key = 'logo_' | append: i
        assign logo = block.settings[logo_key]
        if logo != blank
          assign logo_count = logo_count | plus: 1
        endif
      endfor
    %}

    {% if logo_count > 0 %}
      {% for duplicate in (1..2) %}
        {% for i in (1..20) %}
          {% liquid
            assign logo_key = 'logo_' | append: i
            assign logo = block.settings[logo_key]
          %}
          {% if logo != blank %}
            <div class="ai-logo-marquee-item-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="Logo {{ i }}"
                loading="lazy"
                width="{{ block.settings.logo_size }}"
                height="{{ block.settings.logo_size }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    {% else %}
      {% for i in (1..8) %}
        <div class="ai-logo-marquee-item-{{ ai_gen_id }}">
          <div class="ai-logo-marquee-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</logo-marquee-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoMarquee{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-logo-marquee-track-{{ ai_gen_id }}');
        this.initMarquee();
      }

      initMarquee() {
        if (!this.track) return;

        requestAnimationFrame(() => {
          const trackWidth = this.track.scrollWidth / 2;
          const containerWidth = this.offsetWidth;

          if (trackWidth >= containerWidth) {
            this.track.classList.add('scrolling');
          }
        });
      }
    }

    customElements.define('logo-marquee-{{ ai_gen_id }}', LogoMarquee{{ ai_gen_id }});
  })();
</script>

