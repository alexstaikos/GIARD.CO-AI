{% doc %}
  @prompt
    I want to make a media colouge section here with media blocked for each brand in rectangles. I want to be able to have cover images and titles for each brands and I want the vidoes to all have adjustable corner radiuses. right now we have 5 total brands so lay it out nice like that, I need to be able to upload videos directly, no urls. I also want the collage to be better, there is too much blank space, everything else looks great
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-collage-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-brand-collage__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-brand-collage__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.corner_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
    min-height: 300px;
  }

  .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 2;
  }

  .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 3 / 5;
    grid-row: 1 / 2;
  }

  .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
  }

  .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 2 / 4;
    grid-row: 2 / 3;
  }

  .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(5) {
    grid-column: 4 / 5;
    grid-row: 2 / 3;
  }

  .ai-brand-collage__media-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-brand-collage__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-brand-collage__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-brand-collage__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.title_padding }}px;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
    display: flex;
    align-items: flex-end;
  }

  .ai-brand-collage__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  @media screen and (max-width: 989px) {
    .ai-brand-collage__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }

    .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(1),
    .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(2),
    .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(3),
    .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(4),
    .ai-brand-collage__item-{{ ai_gen_id }}:nth-child(5) {
      grid-column: auto;
      grid-row: auto;
    }

    .ai-brand-collage__item-{{ ai_gen_id }} {
      min-height: 250px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-brand-collage__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-brand-collage__item-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-brand-collage__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<brand-collage-{{ ai_gen_id }} class="ai-brand-collage-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-collage__grid-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'brand_' | append: i | append: '_image'
        assign video_key = 'brand_' | append: i | append: '_video'
        assign title_key = 'brand_' | append: i | append: '_title'
        
        assign brand_image = block.settings[image_key]
        assign brand_video = block.settings[video_key]
        assign brand_title = block.settings[title_key]
      %}
      
      <div class="ai-brand-collage__item-{{ ai_gen_id }}">
        {% if brand_video != blank %}
          {{- brand_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'ai-brand-collage__media-' | append: ai_gen_id -}}
        {% elsif brand_image != blank %}
          <img
            src="{{ brand_image | image_url: width: 1200 }}"
            alt="{{ brand_image.alt | escape }}"
            class="ai-brand-collage__media-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ brand_image.width }}"
            height="{{ brand_image.height }}"
          >
        {% else %}
          <div class="ai-brand-collage__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        
        {% if brand_title != blank %}
          <div class="ai-brand-collage__overlay-{{ ai_gen_id }}">
            <h3 class="ai-brand-collage__title-{{ ai_gen_id }}">{{ brand_title }}</h3>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</brand-collage-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandCollage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('video');
        this.setupVideoPlayback();
      }

      setupVideoPlayback() {
        this.videos.forEach((video) => {
          video.addEventListener('loadedmetadata', () => {
            video.play().catch(() => {});
          });
        });
      }
    }

    customElements.define('brand-collage-{{ ai_gen_id }}', BrandCollage{{ ai_gen_id }});
  })();
</script>

